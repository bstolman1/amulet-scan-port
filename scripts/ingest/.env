# --------------------------------------------
# FETCHER SETTINGS — AGGRESSIVE (finish M3+M4 fast)
# --------------------------------------------
PARALLEL_FETCHES=32
MIN_PARALLEL_FETCHES=12
MAX_PARALLEL_FETCHES=48
# Latency thresholds for auto-tuning (milliseconds)
LATENCY_LOW_MS=800
LATENCY_HIGH_MS=3000
LATENCY_CRITICAL_MS=8000
BATCH_SIZE=1000
# --------------------------------------------
# MIGRATION RANGE — run through M3 and M4
# --------------------------------------------
START_MIGRATION=3
END_MIGRATION=4
# --------------------------------------------
# WORKER THREAD SETTINGS
# --------------------------------------------
# MAX_WORKERS is superseded by PARQUET_WORKERS when both are set.
# It is kept here for write-binary.js which reads it independently.
MAX_WORKERS=24
PARQUET_WORKERS=12
DECODE_WORKERS=12
DECODE_BATCH_SIZE=250
MAX_INFLIGHT_PROCESS=12
# CHUNK_SIZE: removed — not read by any file in this pipeline
# --------------------------------------------
# MEMORY SAFETY
# --------------------------------------------
GLOBAL_DEDUP_MAX=500000
# FIX: HEAP_PRESSURE_THRESHOLD and HEAP_CRITICAL_THRESHOLD were both 0.90
# (CRITICAL was unset and defaulted to 0.90 in code). Equal thresholds collapse
# the two-stage graduated response into one — both fire simultaneously.
# PRESSURE throttles writes; CRITICAL takes more drastic action.
# They must be distinct, with CRITICAL strictly higher than PRESSURE.
HEAP_PRESSURE_THRESHOLD=0.90
HEAP_CRITICAL_THRESHOLD=0.95
# --------------------------------------------
# COMPRESSION SETTINGS
# --------------------------------------------
# ZSTD_LEVEL: removed — not read by any file in this pipeline
# IO_BUFFER_SIZE: removed — not read by any file in this pipeline
# --------------------------------------------
# FILE MANAGEMENT
# --------------------------------------------
MAX_ROWS_PER_FILE=100000
MIN_ROWS_PER_FILE=25000
# FIX: PARQUET_ROW_GROUP was 100000, equal to MAX_ROWS_PER_FILE.
# DuckDB writes row groups of ROW_GROUP_SIZE within each file. When row group
# size >= file size, every file has exactly one partial row group — predicate
# pushdown on reads is disabled for the entire dataset.
# ROW_GROUP should be <= MIN_ROWS_PER_FILE so even the smallest auto-tuned
# files contain at least one complete row group.
PARQUET_ROW_GROUP=25000
PARQUET_VALIDATION_SAMPLE_RATE=20
SCAN_URL=https://scan.sv-1.global.canton.network.sync.global/api/scan
# Local paths (used for cursors even in GCS mode)
DATA_DIR=/home/ben/ledger_data
CURSOR_DIR=/home/ben/ledger_data/cursors
# --------------------------------------------
# GOOGLE CLOUD STORAGE — HIGH THROUGHPUT
# --------------------------------------------
GCS_BUCKET=canton-bucket
GCS_ENABLED=true
GCS_UPLOAD_CONCURRENCY=48
GCS_QUEUE_HIGH_WATER=5000
GCS_QUEUE_LOW_WATER=1000
GCS_BYTE_HIGH_WATER=8589934592
GCS_BYTE_LOW_WATER=2147483648
# FLUSH_INTERVAL_MS: removed — not read by any file; use FLUSH_EVERY_BATCHES instead
# --------------------------------------------
# GROUPS.IO API
# --------------------------------------------
GROUPS_IO_API_KEY=5ed83f0119c9ab75f5af9d980b504672c4b8504a6144d26cb871fdb50aaf0427
