# --------------------------------------------
# FETCHER SETTINGS — AGGRESSIVE (finish M3+M4 fast)
# --------------------------------------------
PARALLEL_FETCHES=32
MIN_PARALLEL_FETCHES=12
MAX_PARALLEL_FETCHES=48

# Latency thresholds for auto-tuning (milliseconds)
LATENCY_LOW_MS=800
LATENCY_HIGH_MS=3000
LATENCY_CRITICAL_MS=8000

BATCH_SIZE=1000

# --------------------------------------------
# MIGRATION RANGE — run through M3 and M4
# --------------------------------------------
START_MIGRATION=3
END_MIGRATION=4

# --------------------------------------------
# WORKER THREAD SETTINGS
# --------------------------------------------
MAX_WORKERS=24
PARQUET_WORKERS=12
DECODE_WORKERS=12
DECODE_BATCH_SIZE=250
MAX_INFLIGHT_PROCESS=12
CHUNK_SIZE=4096

# --------------------------------------------
# MEMORY SAFETY
# --------------------------------------------
GLOBAL_DEDUP_MAX=500000
HEAP_PRESSURE_THRESHOLD=0.90

# --------------------------------------------
# COMPRESSION SETTINGS
# --------------------------------------------
ZSTD_LEVEL=1
IO_BUFFER_SIZE=1048576

# --------------------------------------------
# FILE MANAGEMENT
# --------------------------------------------
