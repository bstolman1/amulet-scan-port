# =============================================================================
# Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in your values
# These are injected at BUILD TIME by Vite (must start with VITE_)

# API Backend URL - leave empty for production (uses relative /api/ paths via nginx)
# Only set this if the API is on a different domain
# VITE_API_BASE_URL=https://api.yourdomain.com

# IMPORTANT: Do NOT set VITE_SCAN_API_URL here!
# The frontend must ONLY use /api/scan-proxy (never direct Scan API calls)
# The backend handles all Scan API routing through endpoint-rotation.js

# Staging build env vars (set at build time, not in this file):
# VITE_BASE_PATH=/staging   - Sets React Router basename
# VITE_BASE=/staging/       - Sets Vite asset base path

# Optional: Feature flags
# VITE_ENABLE_DEBUG=false
# VITE_ENABLE_ANALYTICS=true
